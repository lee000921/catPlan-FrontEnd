<view class="help-container">
  <view class="help-header">
    <view class="header-title">常见问题</view>
    <view class="header-subtitle">以下是用户常见的问题和解答</view>
  </view>
  
  <view class="faq-list">
    <view class="faq-item" wx:for="{{faqList}}" wx:key="question">
      <view class="faq-question" bindtap="toggleFAQ" data-index="{{index}}">
        <text>{{item.question}}</text>
        <view class="arrow {{item.expanded ? 'expanded' : ''}}">▼</view>
      </view>
      <view class="faq-answer {{item.expanded ? 'expanded' : ''}}">
        {{item.answer}}
      </view>
    </view>
  </view>
  
  <view class="contact-section">
    <view class="section-title">联系我们</view>
    <view class="contact-item" bindtap="copyContact" data-type="email">
      <view class="contact-label">电子邮箱</view>
      <view class="contact-value">
        {{contactInfo.email}}
        <text class="copy-text">复制</text>
      </view>
    </view>
    <view class="contact-item" bindtap="copyContact" data-type="phone">
      <view class="contact-label">客服电话</view>
      <view class="contact-value">
        {{contactInfo.phone}}
        <text class="copy-text">复制</text>
      </view>
    </view>
    <view class="contact-item" bindtap="copyContact" data-type="wechat">
      <view class="contact-label">微信客服</view>
      <view class="contact-value">
        {{contactInfo.wechat}}
        <text class="copy-text">复制</text>
      </view>
    </view>
  </view>
  
  <view class="service-button" bindtap="contactService">
    联系在线客服
  </view>
  
  <view class="help-footer">
    <view class="footer-text">猫咪计划 © 2025 版权所有</view>
  </view>
</view>