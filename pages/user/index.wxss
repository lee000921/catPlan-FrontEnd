/* pages/user/index.wxss */
.user-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 40rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.user-header {
  background-color: #ff6b81;
  padding: 40rpx 30rpx;
  position: relative;
  overflow: hidden;
}

.user-header::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #f8f8f8;
  border-radius: 50% 50% 0 0;
  z-index: 1;
}

.user-info {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  background-color: #fff;
}

.info-content {
  flex: 1;
  margin-left: 30rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.login-btn {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.user-level {
  display: flex;
  align-items: center;
}

.level-text {
  font-size: 24rpx;
  color: #fff;
  background-color: rgba(255, 255, 255, 0.3);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 15rpx;
}

.edit-icon {
  color: #fff;
}

.points-card {
  margin: -40rpx 30rpx 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 5;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.points-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.points-rules {
  font-size: 24rpx;
  color: #999;
}

.points-content {
  display: flex;
  align-items: center;
}

.total-points {
  font-size: 60rpx;
  font-weight: bold;
  color: #ff6b81;
  margin-right: 40rpx;
}

.points-detail {
  flex: 1;
  display: flex;
  align-items: center;
}

.detail-item {
  flex: 1;
  text-align: center;
}

.detail-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
}

.detail-divider {
  width: 2rpx;
  height: 40rpx;
  background-color: #eee;
}

.quick-functions {
  margin: 0 30rpx 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 15rpx;
}

.function-icon.checkin {
  background-color: rgba(255, 107, 129, 0.1);
}

.function-icon.tasks {
  background-color: rgba(255, 149, 0, 0.1);
}

.function-icon.exchange {
  background-color: rgba(0, 122, 255, 0.1);
}

.function-text {
  font-size: 26rpx;
  color: #666;
}

.function-list {
  margin: 0 30rpx;
}

.function-group {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.function-item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.function-item-row:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-text {
  font-size: 28rpx;
  color: #333;
  margin-left: 20rpx;
}

.logout-btn {
  margin: 60rpx 30rpx;
  height: 90rpx;
  background-color: #fff;
  color: #ff6b81;
  font-size: 32rpx;
  border-radius: 45rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.app-version {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 60rpx;
}