<view class="profile-container">
  <!-- 头像区域 -->
  <view class="avatar-section">
    <image class="avatar" src="{{userInfo.avatarUrl || '/assets/icons/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="change-avatar-btn" bindtap="changeAvatar">更换头像</view>
  </view>
  
  <!-- 表单区域 -->
  <view class="form-section">
    <!-- 昵称 -->
    <view class="form-item">
      <view class="form-label">昵称</view>
      <input 
        class="form-input" 
        value="{{formData.nickName}}" 
        placeholder="请输入昵称" 
        maxlength="20"
        bindinput="handleInputChange"
        data-field="nickName"
      />
    </view>
    
    <!-- 性别 -->
    <view class="form-item">
      <view class="form-label">性别</view>
      <picker 
        mode="selector" 
        range="{{genderOptions}}" 
        value="{{genderOptions.indexOf(formData.gender)}}" 
        bindchange="handleGenderChange"
      >
        <view class="picker-value">{{formData.gender}} <text class="arrow">▼</text></view>
      </picker>
    </view>
    
    <!-- 生日 -->
    <view class="form-item">
      <view class="form-label">生日</view>
      <picker 
        mode="date" 
        value="{{formData.birthDate !== '请选择' ? formData.birthDate : '2000-01-01'}}" 
        start="1900-01-01" 
        end="2025-12-31" 
        bindchange="handleDateChange"
      >
        <view class="picker-value {{formData.birthDate === '请选择' ? 'placeholder' : ''}}">
          {{formData.birthDate}} <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
    
    <!-- 手机号 -->
    <view class="form-item">
      <view class="form-label">手机号</view>
      <input 
        class="form-input" 
        value="{{formData.phone}}" 
        type="number"
        placeholder="请输入手机号" 
        maxlength="11"
        bindinput="handleInputChange"
        data-field="phone"
      />
    </view>
    
    <!-- 邮箱 -->
    <view class="form-item">
      <view class="form-label">邮箱</view>
      <input 
        class="form-input" 
        value="{{formData.email}}" 
        type="text"
        placeholder="请输入邮箱" 
        bindinput="handleInputChange"
        data-field="email"
      />
    </view>
    
    <!-- 地址 -->
    <view class="form-item">
      <view class="form-label">地址</view>
      <textarea 
        class="form-textarea" 
        value="{{formData.address}}" 
        placeholder="请输入地址" 
        maxlength="100"
        bindinput="handleInputChange"
        data-field="address"
      />
    </view>
  </view>
  
  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="saveProfile" loading="{{loading}}">保存</button>
  
  <!-- 提示信息 -->
  <view class="tips">
    完善个人资料可以获得额外碎片奖励
  </view>
</view>