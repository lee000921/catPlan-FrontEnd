/* pages/user/login.wxss */
.login-container {
  min-height: 100vh;
  background-color: #fff;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #999;
}

.login-methods {
  margin-bottom: 40rpx;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
  border: none;
  position: relative;
}

.login-btn::after {
  border: none;
}

.btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

