  background-image: url("data:image/svg+xml,%3Csvg t='1648636344916' class='icon' viewBox='0 0 1024 1024' version='1.1' xmlns='http://www.w3.org/2000/svg' p-id='6614' width='32' height='32'%3E%3Cpath d='M744.32 959.36H280.32c-47.36 0-86.4-38.4-86.4-86.4V150.4c0-47.36 38.4-86.4 86.4-86.4h464c47.36 0 86.4 38.4 86.4 86.4v722.56c0 48-38.4 86.4-86.4 86.4z m0-64c12.16 0 22.4-10.24 22.4-22.4V150.4c0-12.16-10.24-22.4-22.4-22.4H280.32c-12.16 0-22.4 10.24-22.4 22.4v722.56c0 12.16 10.24 22.4 22.4 22.4h464z' fill='%23333333' p-id='6615'%3E%3C/path%3E%3Cpath d='M512.32 832c-35.2 0-64-28.8-64-64s28.8-64 64-64 64 28.8 64 64-28.8 64-64 64z m0-64v0zM384.32 192h256v64h-256z' fill='%23333333' p-id='6616'%3E%3C/path%3E%3C/svg%3E");
