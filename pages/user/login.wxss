.wechat-btn {
  background-color: #07c160;
  color: #fff;
}

.profile-btn {
  background-color: #ff6b81;
  color: #fff;
}

.phone-btn {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #ddd;
}

.phone-btn .phone-icon {
  filter: brightness(0.5);
}

.privacy-agreement {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox-inner {
  width: 32rpx;
  height: 32rpx;
  border: 1rpx solid #ddd;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox-inner.checked {
  background-color: #ff6b81;
  border-color: #ff6b81;
}

.checkbox-icon {
  color: #fff;
  font-size: 24rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
  flex: 1;
}

.link {
  color: #ff6b81;
}

.login-tips {
  margin-top: auto;
}

.tips-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  text-align: center;
}

.tips-list {
  padding: 0 30rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 15rpx;
  background-image: url("data:image/svg+xml,%3Csvg t='1648636407044' class='icon' viewBox='0 0 1024 1024' version='1.1' xmlns='http://www.w3.org/2000/svg' p-id='7793' width='32' height='32'%3E%3Cpath d='M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64z m193.5 301.7l-210.6 292c-12.7 17.7-39 17.7-51.7 0L318.5 484.9c-3.8-5.3 0-12.7 6.5-12.7h46.9c10.2 0 19.9 4.9 25.9 13.3l71.2 98.8 157.2-218c6-8.3 15.6-13.3 25.9-13.3H699c6.5 0 10.3 7.4 6.5 12.7z' fill='%23ff6b81' p-id='7794'%3E%3C/path%3E%3C/svg%3E");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.tip-item text {
  font-size: 26rpx;
  color: #666;
}