/* pages/user/help.wxss */
.help-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 40rpx;
}

.help-header {
  background-color: #ff6b81;
  padding: 40rpx 30rpx;
  color: #fff;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.8;
}

.faq-list {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 0 30rpx;
}

.faq-item {
  border-bottom: 1rpx solid #f0f0f0;
  padding: 30rpx 0;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s;
}

.arrow.expanded {
  transform: rotate(180deg);
}

.faq-answer {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 0;
  max-height: 0;
  overflow: hidden;
  transition: all 0.3s;
}

.faq-answer.expanded {
  margin-top: 20rpx;
  max-height: 1000rpx;
}

.contact-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 28rpx;
  color: #333;
}

.contact-value {
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
}

.copy-text {
  font-size: 24rpx;
  color: #ff6b81;
  margin-left: 15rpx;
  padding: 4rpx 10rpx;
  border: 1rpx solid #ff6b81;
  border-radius: 20rpx;
}

.service-button {
  margin: 40rpx 30rpx;
  height: 90rpx;
  background-color: #ff6b81;
  color: #fff;
  font-size: 32rpx;
  border-radius: 45rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.help-footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}