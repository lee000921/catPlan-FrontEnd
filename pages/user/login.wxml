<view class="login-container">
  <view class="login-header">
    <image class="logo" src="/assets/icons/default-avatar.png" mode="aspectFit"></image>
    <view class="app-name">猫咪计划</view>
    <view class="app-slogan">每日签到，完成任务，赢取积分</view>
  </view>

  <view class="login-methods">
    <button class="login-btn wechat-btn" bindtap="handleWechatLogin" loading="{{isLoading}}">
      <view class="btn-inner">
        <view class="btn-icon wechat-icon"></view>
        <text>微信一键登录</text>
      </view>
    </button>

    <button class="login-btn profile-btn" bindtap="handleUserProfile" loading="{{isLoading}}">
      <view class="btn-inner">
        <view class="btn-icon profile-icon"></view>
        <text>获取用户信息登录</text>
      </view>
    </button>

    <button class="login-btn phone-btn" bindtap="handlePhoneLogin">
      <view class="btn-inner">
        <view class="btn-icon phone-icon"></view>
        <text>手机号登录/注册</text>
      </view>
    </button>
  </view>

  <view class="privacy-agreement">
    <view class="checkbox" bindtap="togglePrivacyAgreement">
      <view class="checkbox-inner {{agreePrivacy ? 'checked' : ''}}">
        <view class="checkbox-icon" wx:if="{{agreePrivacy}}">✓</view>
      </view>
    </view>
    <view class="agreement-text">
      登录即表示您同意
      <text class="link" bindtap="viewUserAgreement">《用户协议》</text>
      和
      <text class="link" bindtap="viewPrivacyPolicy">《隐私政策》</text>
    </view>
  </view>

  <view class="login-tips">
    <view class="tips-title">登录后即可体验以下功能</view>
    <view class="tips-list">
      <view class="tip-item">
        <view class="tip-icon"></view>
        <text>每日签到获取积分</text>
      </view>
      <view class="tip-item">
        <view class="tip-icon"></view>
        <text>完成任务赢取奖励</text>
      </view>
      <view class="tip-item">
        <view class="tip-icon"></view>
        <text>积分兑换精美礼品</text>
      </view>
    </view>
  </view>
</view>