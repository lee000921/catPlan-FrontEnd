<view class="user-container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." inherit-color />
  </view>

  <block wx:else>
    <!-- 顶部用户信息 -->
    <view class="user-header">
      <view class="user-info" bindtap="{{isLogin ? 'editProfile' : 'goToLogin'}}">
        <image class="avatar" src="{{userInfo.avatarUrl || '/assets/icons/default-avatar.png'}}"></image>
        <view class="info-content">
          <view class="nickname" wx:if="{{isLogin}}">{{userInfo.nickName || '猫咪用户'}}</view>
          <view class="login-btn" wx:else>点击登录</view>
          <view class="user-level" wx:if="{{isLogin}}">
            <text class="level-text">Lv.{{userInfo.level || 1}}</text>
            <text class="user-id">ID: {{userInfo.userId || '未设置'}}</text>
          </view>
        </view>
        <view class="edit-icon" wx:if="{{isLogin}}">
          <t-icon name="chevron-right" size="48rpx" color="#999" />
        </view>
      </view>
    </view>

    <!-- 积分信息 -->
    <view class="points-card">
      <view class="points-header">
        <view class="points-title">我的积分</view>
        <view class="points-rules" bindtap="goToPointsRules">积分规则</view>
      </view>
      <view class="points-content">
        <view class="total-points">{{pointsInfo.total}}</view>
        <view class="points-detail">
          <view class="detail-item">
            <view class="detail-value">{{pointsInfo.thisMonth}}</view>
            <view class="detail-label">本月获得</view>
          </view>
          <view class="detail-divider"></view>
          <view class="detail-item">
            <view class="detail-value">{{pointsInfo.expiring}}</view>
            <view class="detail-label">即将过期</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 快捷功能 -->
    <view class="quick-functions">
      <navigator url="/pages/checkin/index" open-type="switchTab" class="function-item">
        <view class="function-icon checkin">
          <t-icon name="check-circle" size="48rpx" color="#ff6b81" />
        </view>
        <view class="function-text">每日签到</view>
      </navigator>
      <navigator url="/pages/tasks/index" open-type="switchTab" class="function-item">
        <view class="function-icon tasks">
          <t-icon name="task" size="48rpx" color="#ff9500" />
        </view>
        <view class="function-text">任务中心</view>
      </navigator>
      <navigator url="/pages/exchange/index" open-type="switchTab" class="function-item">
        <view class="function-icon exchange">
          <t-icon name="shop" size="48rpx" color="#007aff" />
        </view>
        <view class="function-text">积分兑换</view>
      </navigator>
    </view>

    <!-- 功能列表 -->
    <view class="function-list">
      <view class="function-group">
        <view class="function-item-row" 
              wx:for="{{functionItems}}" 
              wx:key="id" 
              data-id="{{item.id}}" 
              bindtap="handleFunctionItemClick">
          <view class="item-left">
            <t-icon name="{{item.icon}}" size="40rpx" color="#666" />
            <text class="item-text">{{item.text}}</text>
          </view>
          <t-icon name="chevron-right" size="40rpx" color="#ccc" />
        </view>
      </view>

      <view class="function-group">
        <view class="function-item-row" bindtap="contactService">
          <view class="item-left">
            <t-icon name="service" size="40rpx" color="#666" />
            <text class="item-text">联系客服</text>
          </view>
          <t-icon name="chevron-right" size="40rpx" color="#ccc" />
        </view>
      </view>

      <!-- 退出登录 -->
      <view class="logout-btn" wx:if="{{isLogin}}" bindtap="handleLogout">退出登录</view>
    </view>

    <!-- 底部版本信息 -->
    <view class="app-version">猫咪计划 v1.0.0</view>
  </block>
</view>