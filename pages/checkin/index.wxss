/* pages/checkin/index.wxss */
.checkin-container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f8f8f8;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.not-login {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 80vh;
  padding: 0 40rpx;
}

.login-tips {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.checkin-header {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-details {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.points {
  font-size: 28rpx;
  color: #ff6b81;
}

.checkin-stats {
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 30rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.checkin-button-container {
  display: flex;
  justify-content: center;
  margin: 40rpx 0;
}

.checkin-button {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b81, #ff4757);
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 129, 0.4);
  transition: all 0.3s ease;
}

.checkin-button.checked {
  background: linear-gradient(135deg, #b8b8b8, #999999);
  box-shadow: 0 6rpx 20rpx rgba(153, 153, 153, 0.4);
}

.checkin-button.animate {
  animation: pulse 0.5s ease-in-out;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
  }
}

.button-inner {
  text-align: center;
}

.button-text {
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.button-subtext {
  font-size: 24rpx;
  opacity: 0.9;
}

.calendar-container {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.calendar-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: bold;
}

.weekday-header {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.weekday-item {
  width: 14.28%;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
}

.day-item {
  width: 14.28%;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  margin-bottom: 10rpx;
}

.day-number {
  font-size: 28rpx;
  color: #333;
}

.day-item.disabled {
  opacity: 0;
}

.day-item.checked::after {
  content: '';
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(255, 107, 129, 0.1);
  z-index: 1;
}

.day-item.checked .day-number {
  color: #ff6b81;
  font-weight: bold;
  z-index: 2;
}

.day-item.today {
  position: relative;
}

.day-item.today::before {
  content: '';
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 1rpx solid #ff6b81;
  z-index: 1;
}

.rewards-container {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.rewards-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.rewards-list {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}

.reward-item {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  margin-bottom: 20rpx;
}

.reward-item.completed {
  background-color: rgba(255, 107, 129, 0.1);
}

.reward-item.current {
  background-color: rgba(255, 107, 129, 0.2);
  border: 2rpx solid #ff6b81;
}

.reward-day {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.reward-points {
  font-size: 24rpx;
  color: #ff6b81;
}

.reward-status {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
}

.status-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
  color: white;
}

.status-icon.completed {
  background-color: #4cd137;
}

.status-icon.current {
  background-color: #ff6b81;
}

.rules-container {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.rules-content {
  font-size: 28rpx;
  color: #666;
}

.rule-item {
  margin-bottom: 15rpx;
  line-height: 1.5;
}