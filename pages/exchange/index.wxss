/* pages/exchange/index.wxss */
.exchange-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 30rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.user-info-bar {
  background-color: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.user-points {
  display: flex;
  align-items: baseline;
}

.points-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 15rpx;
}

.points-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b81;
}

.login-tip {
  font-size: 28rpx;
  color: #666;
}

.login-btn {
  color: #ff6b81;
  margin-left: 15rpx;
}

.history-btn {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.custom-tabs {
  background-color: #fff;
  margin-bottom: 20rpx;
}

.exchange-list {
  padding: 0 20rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.exchange-item {
  width: 345rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.item-image {
  width: 100%;
  height: 345rpx;
  background-color: #f5f5f5;
}

.item-stock {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
}

.item-stock.out-of-stock {
  background-color: rgba(153, 153, 153, 0.8);
}

.item-info {
  padding: 20rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.item-points {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b81;
  margin-right: 15rpx;
}

.item-original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.item-sold {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.exchange-btn {
  width: 100%;
  height: 60rpx;
  background-color: #ff6b81;
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.exchange-btn.disabled {
  background-color: #ccc;
}

.empty-state {
  padding: 100rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.exchange-rules {
  margin: 30rpx 20rpx 0;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.rules-content {
  font-size: 26rpx;
  color: #666;
}

.rule-item {
  margin-bottom: 15rpx;
  line-height: 1.5;
}