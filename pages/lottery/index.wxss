.lottery-container {
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100vh;
  background-color: #fff8e1;
}

.lottery-title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 30px;
  color: #ff9800;
}

.lottery-wheel-container {
  position: relative;
  width: 300px;
  height: 300px;
  margin-bottom: 40px;
}

.lottery-wheel {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 8px solid #ff9800;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
  will-change: transform;
  overflow: hidden;
}

/* 扇形区域 */
.prize-sector {
  position: absolute;
  width: 100%;
  height: 100%;
  clip-path: polygon(50% 50%, 50% 0, 100% 0, 100% 50%, 50% 50%);
  transform-origin: center;
}

/* 扇形内容 */
.sector-content {
  position: absolute;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 奖品文字 */
.prize-text {
  position: absolute;
  top: 40px;
  left: 75%;
  transform: translateX(-50%) rotate(30deg);
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.7);
  border-radius: 10px;
  padding: 5px 3px;
}

.vertical-char {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  line-height: 1.2;
  text-align: center;
}

/* 指针 */
.lottery-pointer {
  position: absolute;
  top: 50%;
  left: 50%;
  z-index: 10;
  width: 0;
  height: 0;
  transform: translate(-50%, -50%);
}

.lottery-pointer:before {
  content: '';
  position: absolute;
  top: -15px;
  left: -15px;
  width: 30px;
  height: 30px;
  background-color: #ff5722;
  border-radius: 50%;
  box-shadow: 0 0 5px rgba(0, 0, 0, 0.3);
}

.lottery-pointer:after {
  content: '';
  position: absolute;
  top: -40px;
  left: -10px;
  width: 0;
  height: 0;
  border-left: 10px solid transparent;
  border-right: 10px solid transparent;
  border-bottom: 25px solid #ff5722;
}

.lottery-button {
  margin-top: 20px;
  padding: 12px 30px;
  background-color: #ff9800;
  color: white;
  border-radius: 30px;
  font-size: 16px;
  font-weight: bold;
  box-shadow: 0 3px 5px rgba(0, 0, 0, 0.2);
}

.lottery-button.disabled {
  background-color: #ccc;
  pointer-events: none;
}

.lottery-tips {
  margin-top: 20px;
  font-size: 14px;
  color: #888;
}

.back-button {
  margin-top: 20px;
  padding: 10px 20px;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 20px;
  font-size: 14px;
}