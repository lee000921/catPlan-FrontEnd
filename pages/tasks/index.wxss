/* pages/tasks/index.wxss */
.tasks-container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f8f8f8;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.not-login {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 80vh;
  padding: 0 40rpx;
}

.login-tips {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.tasks-overview {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.overview-item {
  text-align: center;
  flex: 1;
}

.overview-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #999;
}

.overview-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #f0f0f0;
}

.task-groups {
  margin-bottom: 30rpx;
}

.task-group {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.group-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.group-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.group-desc {
  font-size: 24rpx;
  color: #999;
}

.task-list {
  padding: 0 30rpx;
}

.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.task-item:last-child {
  border-bottom: none;
}

.task-info {
  flex: 1;
  margin-right: 20rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.task-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.task-progress {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 10rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
  margin-right: 15rpx;
}

.progress-inner {
  height: 100%;
  background-color: #ff6b81;
  border-radius: 10rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  width: 80rpx;
  text-align: right;
}

.task-action {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.task-points {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b81;
  margin-bottom: 15rpx;
}

.task-button {
  width: 140rpx;
  height: 60rpx;
  background-color: #ff6b81;
  color: white;
  font-size: 24rpx;
  border-radius: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.task-button.completed {
  background-color: #999;
}

.task-rules {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.rules-content {
  font-size: 28rpx;
  color: #666;
}

.rule-item {
  margin-bottom: 15rpx;
  line-height: 1.5;
}