<view class="tasks-container">
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." inherit-color />
  </view>

  <block wx:else>
    <!-- 未登录状态 -->
    <view class="not-login" wx:if="{{!isLogin}}">
      <view class="login-tips">登录后开始完成任务获取碎片</view>
      <t-button theme="primary" size="large" bind:tap="goToLogin">去登录</t-button>
    </view>

    <!-- 已登录状态 -->
    <block wx:else>
      <!-- 任务概览 -->
      <view class="tasks-overview">
        <view class="overview-item">
          <view class="overview-value">{{completedTasks}}/{{totalTasks}}</view>
          <view class="overview-label">任务完成</view>
        </view>
        <view class="overview-divider"></view>
        <view class="overview-item">
          <view class="overview-value">{{todayEarnedPoints}}</view>
          <view class="overview-label">今日获得碎片</view>
        </view>
      </view>

      <!-- 任务列表 -->
      <view class="task-groups">
        <view class="task-group" wx:for="{{taskGroups}}" wx:for-item="group" wx:for-index="groupIndex" wx:key="title">
          <view class="group-header">
            <view class="group-title">{{group.title}}</view>
            <view class="group-desc">{{group.desc}}</view>
          </view>
          
          <view class="task-list">
            <view class="task-item" 
                  wx:for="{{group.tasks}}" 
                  wx:for-item="task" 
                  wx:for-index="taskIndex" 
                  wx:key="id"
                  data-group-index="{{groupIndex}}"
                  data-task-index="{{taskIndex}}"
                  bindtap="handleTaskClick">
              
              <view class="task-info">
                <view class="task-title">{{task.title}}</view>
                <view class="task-desc">{{task.desc}}</view>
                
                <!-- 进度条 -->
                <view class="task-progress" wx:if="{{task.maxProgress > 1}}">
                  <view class="progress-bar">
                    <view class="progress-inner" style="width: {{task.progress / task.maxProgress * 100}}%;"></view>
                  </view>
                  <view class="progress-text">{{task.progress}}/{{task.maxProgress}}</view>
                </view>
              </view>
              
              <view class="task-action">
                <view class="task-points">+{{task.points}}</view>
                <view class="task-button {{task.completed ? 'completed' : ''}}">
                  {{task.buttonText}}
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 任务规则 -->
      <view class="task-rules">
        <view class="rules-title">任务规则</view>
        <view class="rules-content">
          <view class="rule-item">1. 日常任务每日0点刷新</view>
          <view class="rule-item">2. 成长任务长期有效，可持续累计</view>
          <view class="rule-item">3. 任务完成后碎片将自动发放</view>
        </view>
      </view>
    </block>
  </block>
</view>