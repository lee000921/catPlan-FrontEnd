# catPlan 后端 - 环境变量配置

## 服务器配置
PORT=3000
NODE_ENV=development

## 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_DATABASE=catplan

## 微信相关配置
WECHAT_APP_ID=wx557d4f3490a318fe
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_API_URL=https://api.weixin.qq.com

## JWT 配置
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRES_IN=7d

## Redis 配置 (可选)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

## 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

## 小程序前端域名 (用于 CORS)
MINI_PROGRAM_DOMAIN=https://your-domain.com

## 阿里云相关配置 (如需使用阿里云服务)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=cn-hangzhou

## API 调用限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

## 邮件配置 (如需要发送邮件通知)
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=

## 其他配置
CORS_ORIGIN=*
API_VERSION=v1
